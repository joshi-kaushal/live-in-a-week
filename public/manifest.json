{
  "manifest_version": 3,
  "name": "Live in a Week",
  "short_name": "Live in a Week",
  "version": "1.0.0",
  "description": "Your weekly planner — always one tab away.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "LiveInAWeek-16.png",
    "24": "LiveInAWeek-24.png",
    "32": "LiveInAWeek-32.png",
    "48": "LiveInAWeek-48.png"
  }
}
